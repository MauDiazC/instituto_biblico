ENV_STATE=dev
DEV_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/institute_dev
PROD_DATABASE_URL=postgresql://postgres:postgres@your-supabase-db:5432/postgres
REDIS_URL=redis://localhost:6379/0

# AWS / S3 (Supabase Storage)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=institute-lms
S3_ENDPOINT_URL=https://your-project-id.supabase.co/storage/v1/s3

# Supabase Auth
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
